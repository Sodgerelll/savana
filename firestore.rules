rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    match /sites/{siteId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();

      match /settings/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /heroBanners/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /collections/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /products/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /markets/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }

      match /testimonials/{documentId} {
        allow read: if true;
        allow create, update, delete: if isSignedIn();
      }
    }

    match /products/{documentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }

    match /collections/{documentId} {
      allow read: if true;
      allow create, update, delete: if isSignedIn();
    }
  }
}
